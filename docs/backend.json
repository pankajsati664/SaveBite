
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "User profile with points and impact tracking.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "store_owner", "customer", "ngo"] },
        "points": { "type": "number", "description": "Gamification points." },
        "impactScore": { "type": "number", "description": "CO2 kg saved." },
        "isBlocked": { "type": "boolean" },
        "preferredLanguage": { "type": "string", "enum": ["en", "hi"] },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "role", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Inventory item with AI and expiry tracking.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "initialPrice": { "type": "number" },
        "currentPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "status": { "type": "string" },
        "imageUrl": { "type": "string" },
        "carbonSaved": { "type": "number" },
        "aiPrediction": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "status", "expiryDate"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "shopId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Profiles" } },
      { "path": "/products_marketplace/{productId}", "definition": { "schema": { "$ref": "#/backend/entities/Product" }, "description": "Public Marketplace" } },
      { "path": "/donations_public/{donationId}", "definition": { "schema": { "type": "object" }, "description": "NGO Pool" } },
      { "path": "/platform_stats/global", "definition": { "schema": { "type": "object" }, "description": "Global Impact Stats" } }
    ]
  }
}
