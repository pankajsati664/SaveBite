
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Global Admin Bypass
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isSignedIn(); // Allow searching users for collaboration
      allow create, update: if isOwner(userId);
    }

    match /stock_images/{imageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_{role}/{uid} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{storeOwnerId}/products/{productId} {
      allow read: if isSignedIn();
      allow write: if isOwner(storeOwnerId) || isAdmin();
    }

    match /products_marketplace/{productId} {
      allow read: if true;
      allow write: if isSignedIn(); // Broad write for prototype, refined by logic
    }

    match /products_donations/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{customerId}/orders/{orderId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId) || isAdmin();
    }

    match /donations_public/{donationId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{ngoId}/claimed_donations/{donationId} {
      allow read, write: if isOwner(ngoId) || isAdmin();
    }
    
    match /platform_stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
