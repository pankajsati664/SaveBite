
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /stock_images/{imageId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_{role}/{uid} {
      allow get: if isSignedIn();
      allow create: if isOwner(uid);
    }

    match /users/{storeOwnerId}/products/{productId} {
      allow read: if isSignedIn();
      allow write: if isOwner(storeOwnerId);
    }

    match /products_marketplace/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /products_donations/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{customerId}/orders/{orderId} {
      allow read: if isOwner(customerId);
      allow create: if isOwner(customerId);
    }

    match /users/{customerId}/orders/{orderId}/orderItems/{orderItemId} {
      allow read: if isOwner(customerId);
      allow create: if isOwner(customerId);
    }

    match /users/{storeOwnerId}/donations/{donationId} {
      allow read: if isSignedIn();
      allow write: if isOwner(storeOwnerId);
    }

    match /donations_public/{donationId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{ngoId}/claimed_donations/{donationId} {
      allow read, write: if isOwner(ngoId);
    }
  }
}
